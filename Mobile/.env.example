# Backend URL the Expo app talks to. Copy this file to `.env` and edit.
#
# - iOS simulator / Android emulator: http://localhost:3000 works.
# - Physical device (Expo Go): must be your DEV MACHINE's LAN IP, because
#   `localhost` on the phone points at the phone, not your laptop.
#   Find it with `ipconfig` on Windows or `ifconfig` on macOS/Linux.
#   Example: API_URL=http://192.168.1.22:3000
# - Production: set this to your deployed backend URL.
API_URL=http://localhost:3000
